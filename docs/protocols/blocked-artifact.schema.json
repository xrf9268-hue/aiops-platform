{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xrf9268-hue/aiops-platform/docs/protocols/blocked-artifact.schema.json",
  "title": "AIOps external blocker artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "reason", "retry_after_seconds"],
  "properties": {
    "version": {
      "const": 1
    },
    "kind": {
      "const": "external_dependency"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "retry_after_seconds": {
      "type": "integer",
      "minimum": 60,
      "maximum": 86400
    }
  }
}
