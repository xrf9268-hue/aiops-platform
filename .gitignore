# Local environment and secrets
.env
.env.*
!.env.example
*.key
*.pem

# Local AI Ops workspaces and caches
aiops-workspaces/
.aiops-workspaces/
workspaces/
.workspaces/
.cache/

# Build outputs and runtime artifacts
dist/
cmd/worker/dashboard/dist/
!cmd/worker/dashboard/dist/README.txt
logs/
docs/validation/smoke/
tmp/
*.log
*.out
*.pid
*.tmp
# Go binaries built at repo root (for example `go build ./cmd/worker ./cmd/tui`)
/worker
/tui
/tui.exe

# Node / npm
node_modules/

# Go test artifacts
coverage.out
*.test

# macOS
.DS_Store

# Local Claude Code state (worktrees, plugin cache, transcripts).
# Project skills under .claude/skills/ are version-controlled per
# https://code.claude.com/docs/en/skills "Share skills → Project skills".
# Shared project settings/scripts are version-controlled; everything else under
# .claude/ stays local.
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/scripts/
!.claude/scripts/**
!.claude/settings.json

# Local Codex CLI state stays out of version control. The project-level config
# keeps AGENTS.md discoverable for Codex sessions; hooks.json is intentionally
# empty so previously installed project hooks are cleared on reload.
.codex/*
!.codex/config.toml
!.codex/hooks.json

# Local Playwright MCP state (browser profile, traces) stays out of version
# control — same rationale as the .claude/ and .codex/ local-state entries.
.playwright-mcp/

# Python cache generated by local/project tooling.
__pycache__/
*.pyc

# Deploy SSH scaffolding (#221) — keep the dir + README tracked, ignore real keys
deploy/ssh/*
!deploy/ssh/.gitkeep
!deploy/ssh/README.md
