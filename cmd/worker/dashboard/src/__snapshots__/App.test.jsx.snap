// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Operations Dashboard > matches the rate-limit panel render snapshot 1`] = `"<div class="flex justify-between gap-4 items-baseline mb-4 flex-wrap"><h2 class="text-base font-semibold tracking-tight">Rate limits</h2><span class="text-muted text-sm">Latest upstream snapshot</span></div><div class="flex flex-col gap-4"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border bg-inset text-muted border-line">pro-tier</span><div class="grid grid-cols-1 sm:grid-cols-3 gap-3"><div class="rounded-xl bg-inset border border-line p-4"><div class="text-xs font-semibold uppercase tracking-wide text-muted">Primary</div><div class="mt-1 text-lg font-semibold tabular-nums text-fg">450 / 500</div><div class="mt-2 h-1.5 w-full rounded-full bg-black/10 dark:bg-white/10 overflow-hidden" role="progressbar" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"><div class="h-full rounded-full bg-good" style="width: 90%;"></div></div><div class="mt-2 text-xs text-muted">resets in 30s</div></div><div class="rounded-xl bg-inset border border-line p-4"><div class="text-xs font-semibold uppercase tracking-wide text-muted">Secondary</div><div class="mt-1 text-lg font-semibold tabular-nums text-fg">18 / 100</div><div class="mt-2 h-1.5 w-full rounded-full bg-black/10 dark:bg-white/10 overflow-hidden" role="progressbar" aria-valuenow="18" aria-valuemin="0" aria-valuemax="100"><div class="h-full rounded-full bg-danger" style="width: 18%;"></div></div><div class="mt-2 text-xs text-muted">resets in 600s</div></div><div class="rounded-xl bg-inset border border-line p-4"><div class="text-xs font-semibold uppercase tracking-wide text-muted">Credits</div><div class="mt-1 text-lg font-semibold tabular-nums text-good">999.00</div></div></div></div>"`;
